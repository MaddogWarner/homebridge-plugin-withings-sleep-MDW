{
  "name": "homebridge-plugin-withings-sleep-mdw",
  "displayName": "Withings Sleep Homebridge Plugin (MDW)",
  "type": "module",
  "version": "2.0.0",
  "packageManager": "pnpm@9.1.0",
  "description": "A simple plugin to expose withings sleep as an occupancy sensor",
  "keywords": [
    "homebridge-plugin"
  ],
  "bugs": {
    "url": "https://github.com/MaddogWarner/homebridge-plugin-withings-sleep-MDW/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaddogWarner/homebridge-plugin-withings-sleep-MDW.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "scripts": {
    "prepare": "husky",
    "clear": "rimraf dist",
    "build": "pnpm run clear && tsc",
    "link": "pnpm link --global",
    "homebridge": "homebridge -I -D",
    "homebridge:ui": "homebridge-config-ui-x -I -D -P 8080",
    "start": "nodemon",
    "watch": "run-s build link start",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run --coverage --mode testing --passWithNoTests",
    "test:watch": "vitest --mode testing",
    "lint": "eslint src",
    "lint:fix": "pnpm run lint --fix",
    "release": "standard-version",
    "release:changelog": "extract-changelog-release > RELEASE.md"
  },
  "dependencies": {
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@dvcol/eslint-plugin-presets": "^1.3.10",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-vitest": "^0.4.1",
    "extract-changelog-release": "^1.0.2",
    "homebridge": "^2.0.0",
    "homebridge-config-ui-x": "^5.23.0",
    "husky": "^9.0.6",
    "lint-staged": "^15.0.0",
    "nodemon": "^3.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "standard-version": "^9.5.0",
    "typescript": "^5.4.5",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "*.{cjs,mjs,js,jsx,ts,tsx,vue,svelte,json,md}": [
      "eslint --fix"
    ]
  },
  "engines": {
    "homebridge": "^1.6.0 || ^2.0.0",
    "node": "^22.12.0 || ^24.0.0"
  }
}
