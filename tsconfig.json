{
  "compilerOptions": {
    "target": "ESNext", // ~node10
    "module": "NodeNext",
    "lib": ["ES2023"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "skipLibCheck": true
  },
  "include": ["src/"],
  "exclude": ["**/*.spec.ts"]
}
